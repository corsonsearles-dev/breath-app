import { useState, useEffect, useRef } from 'react';
import { Play, Pause, RotateCcw } from 'lucide-react';

const GOLD = '#ab914d';

/* ==============================================================
   PRESETS
   Each preset defines duration + target for inhale/exhale
   (target = where the bubble lands at end of phase, 0–100%).
   Holds maintain whatever fullness the previous phase left.
   ============================================================== */
const PRESETS = {
  box: {
    name: 'Box Breathing',
    description: 'Equal four-count breathing — calm focus under pressure.',
    inhale: { duration: 4, target: 100 },
    holdTop: { duration: 4 },
    exhale: { duration: 4, target: 0 },
    holdBottom: { duration: 4 },
  },
  '478': {
    name: '4-7-8 Breathing',
    description: "Dr. Andrew Weil's relaxation pattern — downshifts the nervous system.",
    inhale: { duration: 4, target: 100 },
    holdTop: { duration: 7 },
    exhale: { duration: 8, target: 0 },
    holdBottom: { duration: 0 },
  },
  coherent: {
    name: 'Coherent Breathing',
    description: 'Five-second in, five-second out. Optimizes heart rate variability.',
    inhale: { duration: 5, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 5, target: 0 },
    holdBottom: { duration: 0 },
  },
  resonance: {
    name: 'Resonance Breathing',
    description: '5.5 seconds each way — the resonance frequency for most adults.',
    inhale: { duration: 5.5, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 5.5, target: 0 },
    holdBottom: { duration: 0 },
  },
  triangle: {
    name: 'Triangle Breathing',
    description: 'Inhale, hold, exhale. A simplified box without the bottom hold.',
    inhale: { duration: 4, target: 100 },
    holdTop: { duration: 4 },
    exhale: { duration: 4, target: 0 },
    holdBottom: { duration: 0 },
  },
  relaxing: {
    name: 'Relaxing Breath (2:1)',
    description: 'Exhale twice as long as inhale to signal safety to the body.',
    inhale: { duration: 4, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 8, target: 0 },
    holdBottom: { duration: 0 },
  },
  wimhof: {
    name: 'Wim Hof Style',
    description: 'Full inhale, half exhale — cyclical hyperventilation for energy.',
    inhale: { duration: 1.5, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 1.5, target: 50 },
    holdBottom: { duration: 0 },
  },
  kapalabhati: {
    name: 'Kapalabhati',
    description: 'Skull-Shining Breath. Rapid forceful exhales, passive inhales.',
    inhale: { duration: 0.4, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 0.3, target: 0 },
    holdBottom: { duration: 0 },
  },
  bhastrika: {
    name: 'Bhastrika',
    description: 'Bellows Breath. Rapid, forceful on both inhale and exhale.',
    inhale: { duration: 1, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 1, target: 0 },
    holdBottom: { duration: 0 },
  },
  ujjayi: {
    name: 'Ujjayi',
    description: 'Victorious Breath. Slow breathing with a gentle throat constriction.',
    inhale: { duration: 6, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 6, target: 0 },
    holdBottom: { duration: 0 },
  },
  dirga: {
    name: 'Dirga (Three-Part)',
    description: 'Long breaths with gentle holds. Fills belly, ribs, then chest.',
    inhale: { duration: 6, target: 100 },
    holdTop: { duration: 2 },
    exhale: { duration: 6, target: 0 },
    holdBottom: { duration: 2 },
  },
  bhramari: {
    name: 'Bhramari (Bee Breath)',
    description: 'Long hum on the exhale — soothes the mind and nervous system.',
    inhale: { duration: 4, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 6, target: 0 },
    holdBottom: { duration: 0 },
  },
  deepCalm: {
    name: 'Deep Calm',
    description: 'Extended holds and long exhale for deep relaxation and sleep.',
    inhale: { duration: 4, target: 100 },
    holdTop: { duration: 7 },
    exhale: { duration: 8, target: 0 },
    holdBottom: { duration: 4 },
  },
  sitali: {
    name: 'Sitali (Cooling)',
    description: 'Cooling pranayama — inhale through a curled tongue.',
    inhale: { duration: 4, target: 100 },
    holdTop: { duration: 2 },
    exhale: { duration: 4, target: 0 },
    holdBottom: { duration: 2 },
  },
  samaVritti: {
    name: 'Sama Vritti',
    description: "Equal Breath. Simple 5-and-5 rhythm — yoga's foundational pattern.",
    inhale: { duration: 5, target: 100 },
    holdTop: { duration: 0 },
    exhale: { duration: 5, target: 0 },
    holdBottom: { duration: 0 },
  },
};

const PHASES = ['inhale', 'holdTop', 'exhale', 'holdBottom'];
const PHASE_LABELS = {
  inhale: 'Inhale',
  holdTop: 'Hold',
  exhale: 'Exhale',
  holdBottom: 'Hold',
};

export default function BreathingTimer() {
  const [selectedPreset, setSelectedPreset] = useState('box');
  const [settings, setSettings] = useState(PRESETS.box);
  const [sessionMinutes, setSessionMinutes] = useState(5);

  const [isRunning, setIsRunning] = useState(false);
  const [currentPhase, setCurrentPhase] = useState('inhale');
  const [phaseTimeLeft, setPhaseTimeLeft] = useState(PRESETS.box.inhale.duration);
  const [sessionTimeLeft, setSessionTimeLeft] = useState(5 * 60);
  const [fullness, setFullness] = useState(0);
  const [sessionComplete, setSessionComplete] = useState(false);
  const [breathCount, setBreathCount] = useState(0);

  // Animation refs
  const animationRef = useRef(null);
  const phaseIdxRef = useRef(0);
  const phaseElapsedRef = useRef(0);
  const sessionElapsedRef = useRef(0);
  const phaseStartFullnessRef = useRef(0);
  const lastTimestampRef = useRef(null);
  const settingsRef = useRef(settings);
  const sessionMinutesRef = useRef(sessionMinutes);

  useEffect(() => { settingsRef.current = settings; }, [settings]);
  useEffect(() => { sessionMinutesRef.current = sessionMinutes; }, [sessionMinutes]);

  const getPhaseTarget = (phaseName, s) => {
    if (phaseName === 'inhale') return s.inhale.target / 100;
    if (phaseName === 'exhale') return s.exhale.target / 100;
    return null; // holds
  };
  const getPhaseDuration = (phaseName, s) => s[phaseName].duration;

  const totalCycleDuration =
    settings.inhale.duration + settings.holdTop.duration +
    settings.exhale.duration + settings.holdBottom.duration;
  const canStart = totalCycleDuration > 0;

  const animate = (timestamp) => {
    if (lastTimestampRef.current === null) lastTimestampRef.current = timestamp;
    const delta = (timestamp - lastTimestampRef.current) / 1000;
    lastTimestampRef.current = timestamp;

    phaseElapsedRef.current += delta;
    sessionElapsedRef.current += delta;

    const s = settingsRef.current;
    let phaseName = PHASES[phaseIdxRef.current];
    let phaseDuration = getPhaseDuration(phaseName, s);
    let target = getPhaseTarget(phaseName, s);

    // Advance through phases (handles zero-duration cascades)
    let safety = 20;
    while (phaseElapsedRef.current >= phaseDuration && safety-- > 0) {
      if (target !== null) phaseStartFullnessRef.current = target;
      const overshoot = phaseElapsedRef.current - phaseDuration;
      phaseIdxRef.current = (phaseIdxRef.current + 1) % 4;
      if (phaseIdxRef.current === 0) {
        setBreathCount((c) => c + 1);
      }
      phaseElapsedRef.current = overshoot;
      phaseName = PHASES[phaseIdxRef.current];
      phaseDuration = getPhaseDuration(phaseName, s);
      target = getPhaseTarget(phaseName, s);
    }

    // Compute fullness
    let newFullness;
    if (target === null) {
      newFullness = phaseStartFullnessRef.current;
    } else if (phaseDuration === 0) {
      newFullness = target;
    } else {
      const t = Math.min(1, phaseElapsedRef.current / phaseDuration);
      newFullness =
        phaseStartFullnessRef.current +
        (target - phaseStartFullnessRef.current) * t;
    }

    setFullness(newFullness);
    setCurrentPhase(phaseName);
    setPhaseTimeLeft(Math.max(0, phaseDuration - phaseElapsedRef.current));

    const totalSessionSeconds = sessionMinutesRef.current * 60;
    setSessionTimeLeft(Math.max(0, totalSessionSeconds - sessionElapsedRef.current));

    if (sessionElapsedRef.current >= totalSessionSeconds) {
      cancelAnimationFrame(animationRef.current);
      setIsRunning(false);
      setSessionComplete(true);
      return;
    }

    animationRef.current = requestAnimationFrame(animate);
  };

  const start = () => {
    if (!canStart) return;
    if (sessionComplete) {
      phaseIdxRef.current = 0;
      phaseElapsedRef.current = 0;
      sessionElapsedRef.current = 0;
      phaseStartFullnessRef.current = 0;
      setFullness(0);
      setBreathCount(0);
      setSessionComplete(false);
    }
    setIsRunning(true);
    lastTimestampRef.current = null;
    animationRef.current = requestAnimationFrame(animate);
  };

  const pause = () => {
    setIsRunning(false);
    cancelAnimationFrame(animationRef.current);
  };

  const reset = () => {
    setIsRunning(false);
    cancelAnimationFrame(animationRef.current);
    phaseIdxRef.current = 0;
    phaseElapsedRef.current = 0;
    sessionElapsedRef.current = 0;
    phaseStartFullnessRef.current = 0;
    lastTimestampRef.current = null;
    setFullness(0);
    setCurrentPhase('inhale');
    setPhaseTimeLeft(settings.inhale.duration);
    setSessionTimeLeft(sessionMinutes * 60);
    setSessionComplete(false);
    setBreathCount(0);
  };

  useEffect(() => () => {
    if (animationRef.current) cancelAnimationFrame(animationRef.current);
  }, []);

  // When idle, keep the phase countdown in sync with current settings
  useEffect(() => {
    if (!isRunning) {
      setPhaseTimeLeft(settings[currentPhase].duration);
    }
  }, [settings, currentPhase, isRunning]);

  useEffect(() => {
    if (!isRunning) setSessionTimeLeft(sessionMinutes * 60);
  }, [sessionMinutes, isRunning]);

  const handlePresetChange = (e) => {
    const key = e.target.value;
    setSelectedPreset(key);
    if (PRESETS[key]) setSettings(PRESETS[key]);
  };

  const updateSetting = (phase, field, value) => {
    setSelectedPreset('custom');
    setSettings((prev) => ({
      ...prev,
      [phase]: { ...prev[phase], [field]: value },
    }));
  };

  const formatTime = (seconds) => {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  };

  // Derived: bubble scale and glow intensity
  const scale = 0.04 + fullness * 0.96;
  const glowIntensity = fullness;

  return (
    <div
      className="min-h-screen w-full flex flex-col items-center px-4 py-10"
      style={{
        background: 'radial-gradient(ellipse at center, #0a0908 0%, #000000 70%)',
        fontFamily: "'Manrope', -apple-system, sans-serif",
        color: '#e8e6e1',
      }}
    >
      {/* Font imports */}
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Manrope:wght@200;300;400;500;600&display=swap');

        input[type='number']::-webkit-inner-spin-button,
        input[type='number']::-webkit-outer-spin-button {
          opacity: 0.3;
        }
        input[type='number'] {
          font-variant-numeric: tabular-nums;
        }
        select option {
          background: #0a0908;
          color: #e8e6e1;
        }
        @keyframes phaseFade {
          from { opacity: 0; transform: translateY(4px); }
          to { opacity: 1; transform: translateY(0); }
        }
        .phase-fade {
          animation: phaseFade 0.4s ease-out;
        }
      `}</style>

      {/* ── Title ─────────────────────────────────────── */}
      <div className="mb-2 text-center">
        <div
          className="text-xs uppercase mb-2"
          style={{
            letterSpacing: '0.5em',
            color: GOLD,
            opacity: 0.7,
            fontWeight: 300,
            paddingLeft: '0.5em',
          }}
        >
          Breath
        </div>
        <div className="h-px w-16 mx-auto" style={{ background: GOLD, opacity: 0.35 }} />
      </div>

      {/* ── Bubble ────────────────────────────────────── */}
      <div
        className="relative flex items-center justify-center my-10"
        style={{ width: 'min(78vw, 340px)', height: 'min(78vw, 340px)' }}
      >
        {/* Outermost hairline ring */}
        <div
          className="absolute inset-0 rounded-full"
          style={{ border: '1px solid rgba(255,255,255,0.06)' }}
        />

        {/* Gold thread ring — slightly inset */}
        <div
          className="absolute rounded-full"
          style={{
            top: '4%', left: '4%', right: '4%', bottom: '4%',
            border: `1px solid ${GOLD}`,
            opacity: 0.18,
          }}
        />

        {/* The breathing bubble */}
        <div
          className="absolute rounded-full pointer-events-none"
          style={{
            width: '92%',
            height: '92%',
            transform: `scale(${scale})`,
            background: `radial-gradient(circle,
              rgba(255,255,255,0.92) 0%,
              rgba(232,230,225,0.55) 35%,
              rgba(180,175,165,0.28) 65%,
              rgba(171,145,77,0.18) 88%,
              rgba(171,145,77,0) 100%)`,
            boxShadow: `
              0 0 ${30 + glowIntensity * 70}px rgba(255,255,255,${0.12 + glowIntensity * 0.22}),
              0 0 ${60 + glowIntensity * 120}px rgba(171,145,77,${0.08 + glowIntensity * 0.18}),
              inset 0 0 ${40 + glowIntensity * 60}px rgba(255,255,255,${0.1 + glowIntensity * 0.15})
            `,
          }}
        />
      </div>

      {/* ── Phase Label + Countdown ─────────────────── */}
      <div className="text-center mb-7 min-h-[3.5rem]" key={currentPhase + '-' + breathCount}>
        <div
          className="text-xs uppercase phase-fade"
          style={{
            letterSpacing: '0.45em',
            color: 'rgba(232,230,225,0.75)',
            fontWeight: 400,
            paddingLeft: '0.45em',
          }}
        >
          {PHASE_LABELS[currentPhase]}
        </div>
        {settings[currentPhase].duration > 0 && (
          <div
            className="mt-1 phase-fade"
            style={{
              fontFamily: "'Cormorant Garamond', serif",
              fontSize: '2rem',
              fontWeight: 300,
              color: GOLD,
              fontVariantNumeric: 'tabular-nums',
              lineHeight: 1,
            }}
          >
            {phaseTimeLeft.toFixed(1)}
          </div>
        )}
      </div>

      {/* ── Controls ────────────────────────────────── */}
      <div className="flex items-center gap-4 mb-4">
        <button
          onClick={isRunning ? pause : start}
          disabled={!canStart}
          className="rounded-full flex items-center justify-center transition-all hover:scale-105 active:scale-95 disabled:opacity-30 disabled:cursor-not-allowed"
          style={{
            width: '64px',
            height: '64px',
            border: `1px solid ${GOLD}`,
            background: `radial-gradient(circle, rgba(171,145,77,0.18) 0%, rgba(171,145,77,0.04) 60%, rgba(0,0,0,0) 100%)`,
            boxShadow: isRunning
              ? `inset 0 0 12px rgba(171,145,77,0.25)`
              : `0 0 20px rgba(171,145,77,0.15)`,
          }}
          aria-label={isRunning ? 'Pause' : 'Start'}
        >
          {isRunning ? (
            <Pause size={20} color={GOLD} strokeWidth={1.5} fill={GOLD} />
          ) : (
            <Play size={20} color={GOLD} strokeWidth={1.5} fill={GOLD} style={{ marginLeft: '2px' }} />
          )}
        </button>

        <button
          onClick={reset}
          className="rounded-full flex items-center justify-center transition-all hover:scale-105 active:scale-95"
          style={{
            width: '48px',
            height: '48px',
            border: '1px solid rgba(255,255,255,0.15)',
          }}
          aria-label="Reset"
        >
          <RotateCcw size={15} color="rgba(232,230,225,0.7)" strokeWidth={1.5} />
        </button>
      </div>

      {/* ── Session status ──────────────────────────── */}
      <div
        className="text-xs uppercase mb-2"
        style={{
          letterSpacing: '0.25em',
          color: 'rgba(232,230,225,0.45)',
          fontVariantNumeric: 'tabular-nums',
          paddingLeft: '0.25em',
        }}
      >
        {isRunning || sessionElapsedRef.current > 0 ? (
          <>{formatTime(sessionTimeLeft)} remaining · {breathCount} {breathCount === 1 ? 'breath' : 'breaths'}</>
        ) : (
          <>Session · {sessionMinutes} min</>
        )}
      </div>

      {sessionComplete && (
        <div
          className="mt-3 text-xs uppercase phase-fade"
          style={{
            letterSpacing: '0.4em',
            color: GOLD,
            fontWeight: 400,
            paddingLeft: '0.4em',
          }}
        >
          Session Complete
        </div>
      )}

      {/* ── Settings panel ──────────────────────────── */}
      <div className="w-full max-w-md mt-12 mb-4">
        <div className="h-px w-full mb-8" style={{ background: 'rgba(255,255,255,0.08)' }} />

        {/* Preset */}
        <div className="mb-7">
          <label
            className="block text-[10px] uppercase mb-2.5"
            style={{ letterSpacing: '0.3em', color: 'rgba(232,230,225,0.4)', paddingLeft: '0.3em' }}
          >
            Preset
          </label>
          <select
            value={selectedPreset}
            onChange={handlePresetChange}
            disabled={isRunning}
            className="w-full bg-transparent px-4 py-2.5 text-sm focus:outline-none focus:border-opacity-50 cursor-pointer disabled:opacity-50 appearance-none"
            style={{
              border: '1px solid rgba(255,255,255,0.15)',
              borderRadius: '2px',
              color: '#e8e6e1',
              fontFamily: 'inherit',
              backgroundImage: `url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ab914d' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e")`,
              backgroundRepeat: 'no-repeat',
              backgroundPosition: 'right 0.75rem center',
              backgroundSize: '0.9rem',
              paddingRight: '2.5rem',
            }}
          >
            <option value="custom">— Custom</option>
            {Object.entries(PRESETS).map(([key, p]) => (
              <option key={key} value={key}>{p.name}</option>
            ))}
          </select>
          {PRESETS[selectedPreset] && (
            <p
              className="text-xs mt-3 italic leading-relaxed"
              style={{
                color: 'rgba(232,230,225,0.5)',
                fontFamily: "'Cormorant Garamond', serif",
                fontSize: '0.95rem',
                fontWeight: 400,
              }}
            >
              {PRESETS[selectedPreset].description}
            </p>
          )}
        </div>

        {/* Phase settings */}
        <div className="space-y-3 mb-7">
          <div
            className="text-[10px] uppercase mb-3"
            style={{ letterSpacing: '0.3em', color: 'rgba(232,230,225,0.4)', paddingLeft: '0.3em' }}
          >
            Pattern
          </div>
          <PhaseRow
            label="Inhale"
            duration={settings.inhale.duration}
            target={settings.inhale.target}
            hasTarget
            onDurationChange={(v) => updateSetting('inhale', 'duration', v)}
            onTargetChange={(v) => updateSetting('inhale', 'target', v)}
            disabled={isRunning}
            isActive={isRunning && currentPhase === 'inhale'}
          />
          <PhaseRow
            label="Hold"
            duration={settings.holdTop.duration}
            onDurationChange={(v) => updateSetting('holdTop', 'duration', v)}
            disabled={isRunning}
            isActive={isRunning && currentPhase === 'holdTop'}
          />
          <PhaseRow
            label="Exhale"
            duration={settings.exhale.duration}
            target={settings.exhale.target}
            hasTarget
            onDurationChange={(v) => updateSetting('exhale', 'duration', v)}
            onTargetChange={(v) => updateSetting('exhale', 'target', v)}
            disabled={isRunning}
            isActive={isRunning && currentPhase === 'exhale'}
          />
          <PhaseRow
            label="Hold"
            duration={settings.holdBottom.duration}
            onDurationChange={(v) => updateSetting('holdBottom', 'duration', v)}
            disabled={isRunning}
            isActive={isRunning && currentPhase === 'holdBottom'}
          />
        </div>

        {/* Session length */}
        <div>
          <label
            className="block text-[10px] uppercase mb-2.5"
            style={{ letterSpacing: '0.3em', color: 'rgba(232,230,225,0.4)', paddingLeft: '0.3em' }}
          >
            Session Length
          </label>
          <div className="flex items-center gap-3">
            <input
              type="number"
              min="1"
              max="60"
              value={sessionMinutes}
              onChange={(e) => setSessionMinutes(Math.max(1, Math.min(60, parseInt(e.target.value) || 1)))}
              disabled={isRunning}
              className="w-20 bg-transparent px-3 py-2 text-sm focus:outline-none disabled:opacity-50"
              style={{
                border: '1px solid rgba(255,255,255,0.15)',
                borderRadius: '2px',
                color: '#e8e6e1',
              }}
            />
            <span className="text-xs" style={{ color: 'rgba(232,230,225,0.5)' }}>minutes</span>
          </div>
        </div>

        {/* Footer note */}
        <div
          className="mt-10 text-[11px] leading-relaxed italic text-center"
          style={{
            color: 'rgba(232,230,225,0.35)',
            fontFamily: "'Cormorant Garamond', serif",
            fontSize: '0.85rem',
          }}
        >
          Set a target below 100% on the exhale to model half-breaths<br />
          (e.g. Wim Hof — inhale to 100%, exhale to 50%).<br />
          Zero duration snaps instantly to target.
        </div>
      </div>
    </div>
  );
}

function PhaseRow({ label, duration, target, hasTarget, onDurationChange, onTargetChange, disabled, isActive }) {
  const borderColor = isActive ? GOLD : 'rgba(255,255,255,0.15)';
  const activeOpacity = isActive ? 1 : 0.85;

  return (
    <div
      className="flex items-center gap-3 py-1.5 px-2 rounded-sm transition-all"
      style={{
        background: isActive ? 'rgba(171,145,77,0.06)' : 'transparent',
        opacity: activeOpacity,
      }}
    >
      <label
        className="text-sm flex-shrink-0"
        style={{
          width: '4.2rem',
          color: isActive ? GOLD : 'rgba(232,230,225,0.8)',
          fontWeight: 400,
          letterSpacing: '0.05em',
        }}
      >
        {label}
      </label>

      <div className="flex items-center gap-2">
        <input
          type="number"
          min="0"
          max="60"
          step="0.1"
          value={duration}
          onChange={(e) => onDurationChange(parseFloat(e.target.value) || 0)}
          disabled={disabled}
          className="w-16 bg-transparent px-2 py-1.5 text-sm focus:outline-none disabled:opacity-50 text-center"
          style={{
            border: `1px solid ${borderColor}`,
            borderRadius: '2px',
            color: '#e8e6e1',
          }}
        />
        <span className="text-[10px] uppercase" style={{ color: 'rgba(232,230,225,0.4)', letterSpacing: '0.15em' }}>
          sec
        </span>
      </div>

      {hasTarget && (
        <div className="flex items-center gap-2 ml-auto">
          <span
            className="text-[10px] uppercase italic"
            style={{
              color: 'rgba(232,230,225,0.35)',
              fontFamily: "'Cormorant Garamond', serif",
              fontStyle: 'italic',
              fontSize: '0.8rem',
              letterSpacing: '0.05em',
            }}
          >
            to
          </span>
          <input
            type="number"
            min="0"
            max="100"
            step="5"
            value={target}
            onChange={(e) => onTargetChange(Math.max(0, Math.min(100, parseInt(e.target.value) || 0)))}
            disabled={disabled}
            className="w-14 bg-transparent px-2 py-1.5 text-sm focus:outline-none disabled:opacity-50 text-center"
            style={{
              border: `1px solid ${borderColor}`,
              borderRadius: '2px',
              color: '#e8e6e1',
            }}
          />
          <span className="text-[10px] uppercase" style={{ color: 'rgba(232,230,225,0.4)', letterSpacing: '0.15em' }}>
            %
          </span>
        </div>
      )}
    </div>
  );
}
